# Core Stylist storage/runtime
MIRA_STYLIST_STORAGE_ROOT=output/mira_stylist
MIRA_STYLIST_API_TITLE=MIRA Stylist API
MIRA_STYLIST_API_VERSION=0.1.0
MIRA_STYLIST_DEFAULT_RENDER_MODE=styled_overlay
MIRA_STYLIST_DEFAULT_CAMERA_ANGLE=front

# CatVTON default engine
MIRA_STYLIST_CATVTON_MODE=remote_gpu_api
MIRA_STYLIST_CATVTON_REPO_PATH=/absolute/path/to/third_party/CatVTON
MIRA_STYLIST_CATVTON_PYTHON_BIN=/absolute/path/to/catvton-env/bin/python
MIRA_STYLIST_CATVTON_BASE_MODEL_PATH=booksforcharlie/stable-diffusion-inpainting
MIRA_STYLIST_CATVTON_RESUME_PATH=zhengchong/CatVTON
MIRA_STYLIST_CATVTON_ATTN_VERSION=mix
MIRA_STYLIST_CATVTON_MIXED_PRECISION=no
MIRA_STYLIST_CATVTON_WIDTH=768
MIRA_STYLIST_CATVTON_HEIGHT=1024
MIRA_STYLIST_CATVTON_STEPS=30
MIRA_STYLIST_CATVTON_GUIDANCE_SCALE=2.5
MIRA_STYLIST_CATVTON_REPAINT=true
MIRA_STYLIST_CATVTON_SKIP_SAFETY_CHECK=false
MIRA_STYLIST_CATVTON_SEED=42
MIRA_STYLIST_CATVTON_TIMEOUT_SECONDS=180

# Remote GPU fallback
MIRA_STYLIST_REMOTE_VTON_URL=http://gpu-host:9000
MIRA_STYLIST_REMOTE_VTON_API_PATH=/tryon/jobs
MIRA_STYLIST_REMOTE_VTON_CALLBACK_URL=https://backend-host/tryon/pipeline-jobs/{stylist_job_id}/callback
MIRA_STYLIST_REMOTE_VTON_MODE=async
MIRA_STYLIST_REMOTE_VTON_POLL_INTERVAL_SECONDS=5
MIRA_STYLIST_PUBLIC_BASE_URL=http://127.0.0.1:8000
MIRA_STYLIST_ARTIFACT_BASE_URL=http://127.0.0.1:8000/artifacts
MIRA_STYLIST_ARTIFACT_SIGNING_SECRET=change-me
MIRA_STYLIST_ARTIFACT_URL_TTL_SECONDS=900
MIRA_STYLIST_OBJECT_STORE_MODE=backend_signed
# MIRA_STYLIST_OBJECT_STORE_BASE_URL=https://bucket-or-cdn.example/mira-stylist
MIRA_STYLIST_REMOTE_VTON_TIMEOUT_SECONDS=120

# Optional heavier CV backends
# MIRA_STYLIST_POSE_BACKEND=apple_vision
# MIRA_STYLIST_POSE_RUNNER=/absolute/path/to/pose_runner --image_path {image_path} --view {view} --provider {provider}
# MIRA_STYLIST_HUMAN_SEGMENTATION_BACKEND=apple_vision
# MIRA_STYLIST_HUMAN_SEGMENTATION_RUNNER=/absolute/path/to/human_seg_runner --image_path {image_path} --output_mask_path {output_mask_path} --view {view} --provider {provider}
# MIRA_STYLIST_GARMENT_SEGMENTATION_BACKEND=simple_alpha
# MIRA_STYLIST_GARMENT_SEGMENTATION_RUNNER=/absolute/path/to/garment_seg_runner --image_path {image_path} --output_dir {output_dir} --mask_path {mask_path} --alpha_png_path {alpha_png_path} --provider {provider}

# Legacy VTON adapters kept for fallback/experimentation
# MIRA_STYLIST_VTON_RUNNER=python3 path/to/custom_runner.py {request_json} {output_dir}
# MIRA_STYLIST_VTON_MODEL_PATH=/absolute/path/to/diffusers-inpaint-model
# MIRA_STYLIST_VTON_DEVICE=auto
# MIRA_STYLIST_VTON_DTYPE=float32
# MIRA_STYLIST_VTON_STEPS=24
# MIRA_STYLIST_VTON_GUIDANCE_SCALE=6.5
# MIRA_STYLIST_VTON_STRENGTH=0.88
# MIRA_STYLIST_IDM_VTON_REPO_PATH=/absolute/path/to/IDM-VTON
# MIRA_STYLIST_IDM_VTON_PYTHON_BIN=/absolute/path/to/idm-vton-env/bin/python
# MIRA_STYLIST_IDM_VTON_SERVER_URL=http://127.0.0.1:7860
