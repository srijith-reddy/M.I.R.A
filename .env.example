# Core MIRA
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
WHISPER_MODEL=base
CARTESIA_API_KEY=your_cartesia_api_key
CARTESIA_VOICE=your_cartesia_voice_id
PICOVOICE_ACCESS_KEY=your_picovoice_access_key
WAKEWORD_MODEL=assets/wakewords/Hey-Mira.ppn
WAKEWORD_SENSITIVITY=0.5

# Audio / device settings
RATE=16000
CHANNELS=1
BLOCK_SIZE=512
VAD_AGGRESSIVENESS=2
STOP_MS=1200
TAIL_MS=300
DEVICE=default
USER_NAME=your_name

# MIRA Stylist
# For the fuller Stylist config surface, also see mira_stylist/.env.example
MIRA_STYLIST_CATVTON_MODE=remote_gpu_api
MIRA_STYLIST_CATVTON_REPO_PATH=/absolute/path/to/third_party/CatVTON
MIRA_STYLIST_CATVTON_PYTHON_BIN=/absolute/path/to/catvton-env/bin/python
MIRA_STYLIST_CATVTON_WIDTH=384
MIRA_STYLIST_CATVTON_HEIGHT=512
MIRA_STYLIST_CATVTON_STEPS=20
MIRA_STYLIST_CATVTON_TIMEOUT_SECONDS=900
MIRA_STYLIST_CATVTON_SKIP_SAFETY_CHECK=true
