# MIRA v2 — copy to .env and fill in.
# .env is loaded from the current working directory first, then from the
# OS config dir (printed on first run). CWD values win.
#
# NEVER commit real keys to this file. `.env` is gitignored; `.env.example`
# is not — it's the template shipped to contributors.

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_PLANNER_MODEL=gpt-4o
OPENAI_CLASSIFY_MODEL=gpt-4o-mini
WHISPER_MODEL=whisper-1

# --- Anthropic (optional — used as a planner alternative when configured) ---
ANTHROPIC_API_KEY=
ANTHROPIC_PLANNER_MODEL=claude-sonnet-4-6

# --- Groq (optional — OpenAI-compatible, used as a fast router when set) ---
GROQ_API_KEY=
GROQ_ROUTER_MODEL=llama-3.1-8b-instant

# --- DeepSeek (optional — OpenAI-compatible; strong cheap planner/supervisor) ---
# To route planner traffic to DeepSeek V3, set OPENAI_PLANNER_MODEL=deepseek-chat
# (the gateway dispatches on the model name prefix).
DEEPSEEK_API_KEY=
DEEPSEEK_PLANNER_MODEL=deepseek-chat

# --- Deepgram (primary streaming STT) ---
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3

# --- Cartesia (TTS + STT fallback) ---
CARTESIA_API_KEY=
CARTESIA_VOICE=
CARTESIA_TTS_MODEL=sonic-2
CARTESIA_STT_MODEL=ink-whisper

# --- Wake word ---
# WAKEWORD_BACKEND: auto | porcupine | openwakeword
#   auto → porcupine if PICOVOICE_ACCESS_KEY is set, else openwakeword
# WAKEWORD_MODEL:
#   porcupine:    jarvis | alexa | computer | hey siri | ...
#   openwakeword: hey_jarvis | alexa | hey_mycroft | computer
#                 or path to a custom .onnx (e.g. ./models/hey_mira.onnx)
WAKEWORD_BACKEND=auto
WAKEWORD_MODEL=hey_jarvis
WAKEWORD_SENSITIVITY=0.5

# Picovoice is optional — only needed when WAKEWORD_BACKEND is porcupine
# (or auto-selects it because this key is set). Leave blank to use
# openwakeword (free, local, runs on CPU).
PICOVOICE_ACCESS_KEY=

# --- Browser (Playwright) ---
BROWSER_HEADLESS=true
BROWSER_USER_AGENT=

# --- Brave Search (optional web search; browser agent still works without it) ---
BRAVE_SEARCH_API_KEY=

# --- User identity ---
USER_NAME=Shrey

# --- Audio (optional overrides) ---
# SAMPLE_RATE=16000
# VAD_AGGRESSIVENESS=2
# STOP_MS=700
# TAIL_MS=100
# AUDIO_INPUT_DEVICE=

# --- Logging (optional) ---
# MIRA_LOG_LEVEL=INFO
# MIRA_LOG_JSON=false

# --- Path overrides (optional; defaults follow OS conventions) ---
# MIRA_DATA_DIR=
# MIRA_CONFIG_DIR=
# MIRA_CACHE_DIR=
